{
  "name": "returnshield",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "pnpm dlx vite@8.0.13 --host 0.0.0.0",
    "dev:api": "node --import tsx src/server/index.ts",
    "build": "tsc --noEmit && pnpm dlx vite@8.0.13 build",
    "preview": "pnpm dlx vite@8.0.13 preview --host 0.0.0.0",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "clsx": "latest",
    "cors": "latest",
    "crypto-js": "latest",
    "date-fns": "latest",
    "dotenv": "latest",
    "express": "latest",
    "helmet": "latest",
    "lucide-react": "latest",
    "morgan": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-router": "latest",
    "tailwind-merge": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/morgan": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "autoprefixer": "latest",
    "concurrently": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "nodemon": "latest",
    "postcss": "latest",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vitest": "^2.1.8",
    "supertest": "^7.1.1",
    "@types/supertest": "^6.0.3"
  },
  "packageManager": "pnpm"
}
